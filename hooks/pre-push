#!/usr/bin/env bash
#
# Pre-push hook - Runs before pushing to remote
# Installed via workspace-hooks-install
#

set -e

# Get the remote and branch being pushed to
remote="$1"
url="$2"

# If repository has a pre-push command defined, run it
if command -v prek &> /dev/null; then
  prek run pre-push 2>/dev/null || true
fi

exit 0
