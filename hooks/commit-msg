#!/bin/bash
# Validate commit message minimum length. Skips merge commits.

MSG_FILE="$1"
MSG="$(head -1 "$MSG_FILE")"

# Skip merge commits
if echo "$MSG" | grep -qE '^Merge '; then
  exit 0
fi

if [ "${#MSG}" -lt 10 ]; then
  echo "❌ Commit message too short (${#MSG} chars, minimum 10)."
  exit 1
fi
