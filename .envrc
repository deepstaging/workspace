#!/usr/bin/env bash

# Deepstaging Workspace .envrc
# This file is copied to the parent directory by bootstrap.sh
# Run 'refresh' script to regenerate PATH for repository scripts

# Export standard Deepstaging environment variables
export DEEPSTAGING_ORG_ROOT="$(pwd)"

export DEEPSTAGING_ORG_NAME="Deepstaging"
export DEEPSTAGING_GITHUB_ORG="deepstaging"

export DEEPSTAGING_ARTIFACTS_DIR="$DEEPSTAGING_ORG_ROOT/artifacts"
export DEEPSTAGING_LOCAL_NUGET_FEED="$DEEPSTAGING_ORG_ROOT/packages"
export DEEPSTAGING_REPOSITORIES_DIR="$DEEPSTAGING_ORG_ROOT/repositories"
export DEEPSTAGING_WORKSPACE_DIR="$DEEPSTAGING_ORG_ROOT/workspace"

# Load Homebrew environment if available (helps with gh, jq, etc.)
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# Add workspace scripts to PATH
PATH_add "$DEEPSTAGING_WORKSPACE_DIR/scripts"

# Add workspace node_modules to PATH
PATH_add "$DEEPSTAGING_WORKSPACE_DIR/node_modules/.bin"

# Add repository script commands to PATH (managed by refresh script)
PATH_add "$DEEPSTAGING_ORG_ROOT/.direnv/bin"

