#!/usr/bin/env bash

# Deepstaging Workspace .envrc
# This file is copied to the parent directory by bootstrap.sh
# It loads scripts from all repository subdirectories into PATH

# Enable debugging (set to 1 to see what's happening)
DEBUG_ENVRC=${DEBUG_ENVRC:-0}

debug() {
    if [[ "$DEBUG_ENVRC" == "1" ]]; then
        echo "[direnv debug] $*" >&2
    fi
}

debug "Starting .envrc processing"
debug "Current directory: $(pwd)"

# Export standard Deepstaging environment variables
# These are available to all scripts in the workspace
export DEEPSTAGING_ORG_ROOT="$(pwd)"
export DEEPSTAGING_WORKSPACE_DIR="$DEEPSTAGING_ORG_ROOT/workspace"
export DEEPSTAGING_GITHUB_ORG="deepstaging"
export DEEPSTAGING_LOCAL_NUGET_FEED="$HOME/.nuget/local-feed"

debug "Environment variables set:"
debug "  DEEPSTAGING_ORG_ROOT=$DEEPSTAGING_ORG_ROOT"
debug "  DEEPSTAGING_WORKSPACE_DIR=$DEEPSTAGING_WORKSPACE_DIR"
debug "  DEEPSTAGING_GITHUB_ORG=$DEEPSTAGING_GITHUB_ORG"
debug "  DEEPSTAGING_LOCAL_NUGET_FEED=$DEEPSTAGING_LOCAL_NUGET_FEED"

# Use direnv's standard library if available
# This provides helpers like layout, use, and source_up
# See: https://direnv.net/man/direnv-stdlib.1.html

# Load Homebrew environment if available (helps with gh, jq, etc.)
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    debug "Loaded Homebrew from /opt/homebrew"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
    debug "Loaded Homebrew from /usr/local"
fi

# Scan all subdirectories for scripts directories
# and add them to PATH with prefixed symlinks

debug "Scanning for repositories with scripts..."
script_count=0

# Create a temporary bin directory for prefixed script wrappers
SCRIPT_BIN_DIR="$PWD/.direnv/bin"
mkdir -p "$SCRIPT_BIN_DIR"

for dir in */; do
    dir_name="${dir%/}"
    # Normalize to lowercase snake_case for prefix
    normalized_name=$(echo "$dir_name" | sed 's/\([A-Z]\)/_\L\1/g' | sed 's/^_//' | tr '-' '_')
    
    scripts_dir="${dir}scripts"
    
    # Check if scripts directory exists
    if [[ -d "$scripts_dir" ]]; then
        debug "Found scripts directory: $scripts_dir"
        
        # Check if parent has package.json (TypeScript scripts)
        has_package_json=false
        if [[ -f "${dir}package.json" ]]; then
            has_package_json=true
            debug "  Repository has package.json (TypeScript scripts available)"
        fi
        
        # Create symlinks/wrappers for each script
        for script in "$scripts_dir"/*; do
            # Check if it's a file or symlink to a file, and executable
            if [[ (-f "$script" || -L "$script") && -x "$script" ]]; then
                script_name=$(basename "$script")
                
                # Handle TypeScript scripts (.ts files with package.json)
                if [[ "$script_name" == *.ts && "$has_package_json" == true ]]; then
                    # TypeScript script - create npm wrapper
                    base_name="${script_name%.ts}"
                    prefixed_name="${normalized_name}-${base_name}"
                    
                    cat > "$SCRIPT_BIN_DIR/$prefixed_name" << WRAPPER
#!/usr/bin/env bash
# Auto-generated wrapper for TypeScript script: $base_name
REPO_DIR="\${DEEPSTAGING_ORG_ROOT:-\$(cd "\$(dirname "\$0")/../.." && pwd)}/$dir_name"
cd "\$REPO_DIR" && npm run $base_name -- "\$@"
WRAPPER
                    chmod +x "$SCRIPT_BIN_DIR/$prefixed_name"
                    debug "  Created command: $prefixed_name (npm run $base_name)"
                    ((script_count++))
                    
                # Handle bash scripts (.sh or no extension)
                else
                    # Bash script - create symlink
                    base_name="${script_name%.sh}"
                    prefixed_name="${normalized_name}-${base_name}"
                    ln -sf "$PWD/$script" "$SCRIPT_BIN_DIR/$prefixed_name"
                    debug "  Created command: $prefixed_name -> $script"
                    ((script_count++))
                fi
            fi
        done
    fi
done

debug "Created $script_count script commands"

# Add the bin directory to PATH
PATH_add "$SCRIPT_BIN_DIR"
debug "Added $SCRIPT_BIN_DIR to PATH"

# Also add workspace scripts to PATH directly for convenience (unprefixed)
if [[ -d "workspace/scripts" ]]; then
    PATH_add workspace/scripts
    debug "Added workspace/scripts to PATH"
else
    debug "Warning: workspace/scripts directory not found"
fi

# Add npm bin directory for workspace node modules
if [[ -d "workspace/node_modules/.bin" ]]; then
    PATH_add workspace/node_modules/.bin
    debug "Added workspace/node_modules/.bin to PATH"
fi

debug "Finished .envrc processing"
