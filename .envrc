# Deepstaging workspace — auto-loaded by direnv
# The workspace repo IS the org root.

export DEEPSTAGING_ORG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export DEEPSTAGING_ORG_NAME="Deepstaging"
export DEEPSTAGING_GITHUB_ORG="deepstaging"
export DEEPSTAGING_WORKSPACE_DIR="$DEEPSTAGING_ORG_ROOT"
export DEEPSTAGING_LOCAL_NUGET_FEED="$DEEPSTAGING_ORG_ROOT/packages"

# Prevent Verify/DiffEngine from auto-launching IDE diff tools.
# Use `dotnet verify review` or `dotnet verify accept` instead.
export DiffEngine_Disabled=true

PATH_add "$DEEPSTAGING_ORG_ROOT/scripts"
