#!/bin/bash

# Deepstaging Workspace .envrc
# This file is copied to the parent directory by bootstrap.sh
# It loads scripts from all repository subdirectories as prefixed aliases

# Use direnv's standard library if available
# This provides helpers like layout, use, and source_up
# See: https://direnv.net/man/direnv-stdlib.1.html

# Load Homebrew environment if available (helps with gh, jq, etc.)
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# Scan all subdirectories for scripts directories
# and create prefixed aliases for each script

for dir in */; do
    dir_name="${dir%/}"
    # Normalize to lowercase snake_case
    normalized_name=$(echo "$dir_name" | sed 's/\([A-Z]\)/_\L\1/g' | sed 's/^_//')
    
    scripts_dir="${dir}scripts"
    
    # Check if scripts directory exists
    if [[ -d "$scripts_dir" ]]; then
        # Create aliases for each executable script
        for script in "$scripts_dir"/*; do
            if [[ -f "$script" && -x "$script" ]]; then
                script_name=$(basename "$script")
                # Remove .sh extension if present
                alias_name="${script_name%.sh}"
                # Create prefixed alias
                alias "${normalized_name}-${alias_name}=$script"
            fi
        done
    fi
done

# Add workspace scripts to PATH for convenience
if [[ -d "workspace/scripts" ]]; then
    PATH_add workspace/scripts
fi
