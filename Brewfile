# Deepstaging Workspace Dependencies
#
# Install all dependencies for workspace scripts and tooling:
#   brew bundle install

# Core dependencies
brew "bash"            # Modern Bash (4.0+) for script features like mapfile
brew "gh"              # GitHub CLI - for repo discovery and operations
brew "direnv"          # Directory-specific environment variables
brew "git"             # Version control

# .NET development (if not already installed via dotnet-install.sh)
# Uncomment if you want Homebrew to manage .NET SDK
# cask "dotnet-sdk"

# Optional but recommended
brew "jq"              # JSON parsing for script automation
brew "tree"            # Directory visualization
brew "ripgrep"         # Fast text search across repos
brew "fzf"             # Fuzzy finder for interactive selections

# AI assistance
cask "copilot-cli"     # GitHub Copilot CLI for AI-powered commit messages
