<Project>
  <!--
    Build.Language.props (workspace-level)

    Org-wide C# language and compiler standards.
    Imported by each repo's Directory.Build.props.
  -->

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
